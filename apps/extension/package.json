{
  "name": "extension",
  "displayName": "VantageUI Extension",
  "version": "0.0.1",
  "description": "VantageUI Browser Extension",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@hookform/resolvers": "^3.10.0",
    "@vantage-ui/ui": "workspace:*",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.344.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.75.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "5.3.3",
    "vitest": "^4.1.5"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ],
    "permissions": [
      "activeTab",
      "storage",
      "scripting",
      "sidePanel"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "action": {},
    "commands": {
      "toggle-inspector": {
        "suggested_key": {
          "default": "Ctrl+Shift+X",
          "mac": "Command+Shift+X"
        },
        "description": "Toggle VantageUI Inspector"
      }
    }
  }
}
